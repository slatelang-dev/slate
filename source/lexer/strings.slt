module strings;

use token;
use chars;

list(Token) read_string(list(string) chars, LexState s) {
    mutable LexState cs = advance(chars, s);
    mutable list(Token) results = empty;
    mutable string current = "";
    mutable int seg_line = state_line(cs);
    mutable int seg_col  = state_col(cs);
    mutable bool running = true;

    while running {
        string ch = current_char(chars, cs);
        if ch == "\"" or ch == "" {
            running = false;
        } else if ch == "&" and peek_char(chars, cs) == "{" {
            if current.len() > 0 {
                results = results.add(Token(kind: TokenKind.StringLit, value: current, line: seg_line, col: seg_col));
                current = "";
            }
            cs = advance(chars, cs);
            cs = advance(chars, cs);
            mutable string ident = "";
            mutable bool reading = true;
            while reading {
                string ic = current_char(chars, cs);
                if ic == "}" or ic == "" {
                    reading = false;
                } else {
                    ident = ident + ic;
                    cs = advance(chars, cs);
                }
            }
            cs = advance(chars, cs);
            results = results.add(Token(kind: TokenKind.Interp, value: ident, line: state_line(cs), col: state_col(cs)));
            seg_line = state_line(cs);
            seg_col  = state_col(cs);
        } else if ch == "\\" {
            cs = advance(chars, cs);
            string esc = current_char(chars, cs);
            cs = advance(chars, cs);
            if esc == "n"  { current = current + "\n"; }
            else if esc == "t"  { current = current + "\t"; }
            else if esc == "r"  { current = current + "\r"; }
            else if esc == "\\" { current = current + "\\"; }
            else if esc == "\"" { current = current + "\""; }
            else if esc == "u" {
                mutable string hex = "";
                mutable int k = 0;
                while k < 4 {
                    mutable string digit = current_char(chars, cs);
                    if digit == "" { digit = "0"; }
                    if digit == "0" or digit == "1" or digit == "2" or digit == "3" or digit == "4" 
                    or digit == "5" or digit == "6" or digit == "7" or digit == "8" or digit == "9"
                    or digit == "a" or digit == "A" or digit == "b" or digit == "B" or digit == "c" or digit == "C"
                    or digit == "d" or digit == "D" or digit == "e" or digit == "E" or digit == "f" or digit == "F" {
                        hex = hex + digit;
                        cs = advance(chars, cs);
                        k = k + 1;
                    } else {
                        k = 4;
                    }
                }
                while hex.len() < 4 {
                    hex = hex + "0";
                }
                mutable int code = 0;
                mutable int j = 0;
                list(string) hex_chars = hex.chars();
                while j < hex.len() {
                    mutable string d = hex_chars.get(j);
                    mutable int val = 0;
                    if d == "0" { val = 0; }
                    else if d == "1" { val = 1; }
                    else if d == "2" { val = 2; }
                    else if d == "3" { val = 3; }
                    else if d == "4" { val = 4; }
                    else if d == "5" { val = 5; }
                    else if d == "6" { val = 6; }
                    else if d == "7" { val = 7; }
                    else if d == "8" { val = 8; }
                    else if d == "9" { val = 9; }
                    else if d == "a" or d == "A" { val = 10; }
                    else if d == "b" or d == "B" { val = 11; }
                    else if d == "c" or d == "C" { val = 12; }
                    else if d == "d" or d == "D" { val = 13; }
                    else if d == "e" or d == "E" { val = 14; }
                    else if d == "f" or d == "F" { val = 15; }
                    code = code * 16 + val;
                    j = j + 1;
                }
                if code >= 32 and code < 127 {
                    string ascii = "                                 !\"#$%&'()*+,-./0123456789:;<=>?@ABCDEFGHIJKLMNOPQRSTUVWXYZ[\\]^_`abcdefghijklmnopqrstuvwxyz{|}~";
                    list(string) ascii_chars = ascii.chars();
                    current = current + ascii_chars.get(code - 32);
                } else if code == 27 {
                    current = current + "\\e";
                }
            }
        } else {
            if current == "" {
                seg_line = state_line(cs);
                seg_col  = state_col(cs);
            }
            current = current + ch;
            cs = advance(chars, cs);
        }
    }

    cs = advance(chars, cs);

    if current.len() > 0 {
        results = results.add(Token(kind: TokenKind.StringLit, value: current, line: seg_line, col: seg_col));
    }
    if results.len() == 0 {
        results = results.add(Token(kind: TokenKind.StringLit, value: "", line: state_line(s), col: state_col(s)));
    }

    return results;
}

LexState string_end_state(list(string) chars, LexState s) {
    mutable LexState cs = advance(chars, s);
    mutable bool running = true;
    while running {
        string ch = current_char(chars, cs);
        if ch == "\"" or ch == "" {
            running = false;
        } else if ch == "\\" {
            cs = advance(chars, cs);
            cs = advance(chars, cs);
        } else {
            cs = advance(chars, cs);
        }
    }
    cs = advance(chars, cs);
    return cs;
}
